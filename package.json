{
  "name": "choral-forma",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=24.11.0 <25"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/choral-io/choral-forma.git"
  },
  "scripts": {
    "lint": "pnpm --recursive --if-present lint",
    "build": "pnpm --recursive --if-present build",
    "test": "vitest run",
    "check": "pnpm --recursive --if-present check && prettier --check . --cache",
    "format": "prettier --write . --cache"
  },
  "devDependencies": {
    "@eslint/js": "~10.0.1",
    "eslint": "~10.5.0",
    "eslint-config-prettier": "~10.1.8",
    "eslint-plugin-prettier": "~5.5.6",
    "prettier": "~3.8.4",
    "prettier-plugin-organize-imports": "~4.3.0",
    "prettier-plugin-tailwindcss": "~0.8.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "~8.61.1",
    "vitest": "~4.1.9"
  }
}
