{
  "schemaVersion": 1,
  "workspace": {
    "name": "Choral Forma Example",
    "canonicalLanguage": "en",
    "supportedLanguages": [
      "en"
    ]
  },
  "spaces": [
    {
      "id": "notes",
      "title": "Notes",
      "display": {
        "order": 10
      },
      "include": "notes/**/*.md",
      "entryCount": 6
    },
    {
      "id": "todos",
      "title": "Todos",
      "display": {
        "order": 20
      },
      "include": "todos/**/*.md",
      "entryCount": 4
    },
    {
      "id": "users",
      "title": "Users",
      "display": {
        "order": 30
      },
      "include": "users/**/*.md",
      "entryCount": 2
    }
  ],
  "views": [
    {
      "id": "graph",
      "path": ".forma/views/graph.md",
      "surface": "page",
      "mode": "graph",
      "source": {
        "kind": "workspace",
        "include": [
          "**/*.md"
        ],
        "exclude": [
          ".forma/**"
        ]
      },
      "title": "Graph",
      "display": {
        "order": 10
      }
    },
    {
      "id": "guide",
      "path": ".forma/views/guide.md",
      "surface": "page",
      "mode": "graph",
      "space": "notes",
      "source": {
        "kind": "workspace",
        "include": [
          "notes/**/*.md"
        ]
      },
      "title": "Guide",
      "display": {
        "order": 20
      }
    },
    {
      "id": "notes",
      "path": ".forma/views/notes.md",
      "surface": "page",
      "mode": "table",
      "space": "notes",
      "title": "Notes",
      "display": {
        "order": 30
      }
    },
    {
      "id": "recent",
      "path": ".forma/views/recent.md",
      "surface": "page",
      "mode": "list",
      "space": "notes",
      "title": "Recent",
      "display": {
        "order": 40
      }
    },
    {
      "id": "todos",
      "path": ".forma/views/todos.md",
      "surface": "page",
      "mode": "kanban",
      "space": "todos",
      "title": "Todos",
      "display": {
        "order": 50
      }
    },
    {
      "id": "users",
      "path": ".forma/views/users.md",
      "surface": "page",
      "mode": "table",
      "space": "users",
      "title": "Users",
      "display": {
        "order": 60
      }
    }
  ],
